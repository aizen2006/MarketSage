JWT_SECRET="your-jwt-secret"
PORT=3000
CORS_ORIGIN="http://localhost:3001"
# Use a single line; no duplicate key. For Neon: add ?sslmode=require
DATABASE_URL="postgresql://marketsage:marketsage@db:5432/marketsage?schema=public"
# Required for /agents/* (quick, deep, auto, title). Missing key logs a startup warning and agent requests will fail.
OPENAI_API_KEY="your-openai-api-key"
QDRANT_API_KEY="your-qdrant-api-key"
QDRANT_URL="https://your-qdrant-host:6333"
TAVILY_API_KEY="your-tavily-api-key"
# Required when quick/deep agent calls fin_research (e.g. Financial Modeling Prep). Missing key causes agent runs to fail.
FMP_API_KEY="your-fmp-api-key"

